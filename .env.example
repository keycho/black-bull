# black bull multiplayer (supabase realtime). create a fresh supabase project,
# then copy these from Project Settings -> API. these are public client values
# (the anon key is publishable / RLS-gated) and get inlined at build.
# leave them unset to run pure solo play (host-of-one, same game).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# $ansem claims (play to earn). leave unset and the earn ledger still runs -
# players stack herd points and the claim button says "claims open soon".
# set this to your payout service url to arm live claims. the service MUST
# re-validate + rate-limit server-side; the client ledger is not a security
# boundary. never put treasury keys anywhere near the client.
VITE_EARN_CLAIM_URL=
